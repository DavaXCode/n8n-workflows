      "id": "d9f27bc5-e158-4e4d-92fe-c848ee233b1d",
      "name": "Gmail Trigger",
      "type": "n8n-nodes-base.gmailTrigger",
      "typeVersion": 1.3,
      "position": [
        -240,
        640
      ]
    },
    {
      "parameters": {
        "jsCode": "const items = [];\nfor (const item of $input.all()) {\n  const e = item.json;\n  const headers = e.headers || {};\n  const fromHeader = e.from?.text ?? e.from?.value?.[0]?.address ?? headers.from ?? '';\n  const fromName = e.from?.value?.[0]?.name ?? (fromHeader.split('<')[0] || '').trim();\n  const fromEmail = e.from?.value?.[0]?.address ?? (fromHeader.match(/<(.+?)>/)?.[1] ?? fromHeader).trim();\n  const subject = e.subject || headers.subject || '(no subject)';\n  const bodyText = (e.text || '').trim() || (e.snippet || '').trim();\n  const body = bodyText.length > 2000 ? bodyText.slice(0, 2000) + '\\n...[truncated]' : bodyText;\n  items.push({ json: {\n    messageId: e.id,\n    threadId: e.threadId,\n    rfc822MessageId: e.messageId || headers['message-id'] || '',\n    fromEmail,\n    fromName: fromName || fromEmail,\n    subject,\n    body,\n    receivedAt: new Date().toISOString()\n  }});\n}\nreturn items;"
      },
      "id": "ac7e8f49-1903-449f-b93b-b2ab73b1c476",
      "name": "Extract Email",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -16,
        640
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Classify this incoming email and return a JSON verdict.\n\nFrom: {{ $json.fromName }} <{{ $json.fromEmail }}>\nSubject: {{ $json.subject }}\n\nBody:\n{{ $json.body }}\n\nGuidelines:\n- intent=meeting when the sender is asking to schedule a call, demo, meeting, or sync.\n- intent=lead when the sender expresses interest in services, pricing, hiring, or a project but is NOT yet asking to schedule.\n- intent=spam for newsletters, marketing blasts, cold outbound that is clearly automated, notifications, OTP codes, receipts.\n- urgency: low | normal | high (high only when the message explicitly requires a response within 24h).\n- summary: one sentence, max 140 chars, factual.\n- sender_name: best guess at first name only.",
        "hasOutputParser": true,
        "messages": {
          "messageValues": [
            {
              "message": "You are an executive assistant triaging an inbox. You return strict JSON only — no prose, no markdown. Intents are exactly one of: meeting | lead | spam. Confidence is 0.0–1.0."
            }
          ]
        },
        "batching": {}
      },
      "id": "15ea446e-0ffb-4e32-bb54-81069bfdcde3",
      "name": "Groq Classifier",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        208,
        640
      ]
    },
    {
      "parameters": {
        "model": "llama-3.3-70b-versatile",
        "options": {
          "maxTokensToSample": 300,
          "temperature": 0.1
        }
      },
      "id": "cd0a0e09-8c0f-4ccf-9f20-32f094c06a93",
      "name": "Groq — Classifier Model",
      "type": "@n8n/n8n-nodes-langchain.lmChatGroq",
      "typeVersion": 1,
      "position": [
        176,
        864
      ]
    },
    {
      "parameters": {
        "jsonSchemaExample": "{ \"intent\": \"meeting\", \"confidence\": 0.92, \"summary\": \"Asking to schedule a 30-min intro call next week.\", \"urgency\": \"normal\", \"sender_name\": \"Jamie\" }"
      },
      "id": "572b11ab-e998-4af7-b92c-7eac6a55dfb0",
      "name": "Triage JSON Parser",
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
      "typeVersion": 1.3,
      "position": [
        384,
        896
      ]
    },
    {
      "parameters": {
        "jsCode": "const email = $('Extract Email').first().json;\nconst out = $input.first().json.output ?? {};\nconst allowed = ['meeting', 'lead', 'spam'];\nlet intent = String(out.intent || '').toLowerCase();\nif (!allowed.includes(intent)) intent = 'lead';\nconst confidence = Math.max(0, Math.min(1, Number(out.confidence) || 0.5));\nconst summary = String(out.summary || email.subject).slice(0, 140);\nconst urgency = ['low','normal','high'].includes(String(out.urgency)) ? out.urgency : 'normal';\nconst sender_name = String(out.sender_name || email.fromName.split(' ')[0] || 'there').slice(0, 40);\n\nconst branchIndex = intent === 'meeting' ? 0 : intent === 'lead' ? 1 : 2;\n\nreturn [{ json: { ...email, intent, confidence, summary, urgency, sender_name, _branch: branchIndex } }];"
      },
      "id": "1e6fefb6-c00a-4cab-a8b0-a290b7c079ee",
      "name": "Parse Classification",
      "type": "n8n-nodes-base.code",
