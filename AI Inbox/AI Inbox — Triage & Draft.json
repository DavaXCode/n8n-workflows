      "id": "e84133da-c190-4984-b2e1-2e648676511b",
      "name": "Calendar Free/Busy",
      "type": "n8n-nodes-base.googleCalendar",
      "typeVersion": 1.3,
      "position": [
        1008,
        352
      ]
    },
    {
      "parameters": {
        "jsCode": "const { DateTime } = require('luxon');\nconst tz = $env.USER_TZ || 'Europe/Bucharest';\nconst email = $('Parse Classification').first().json;\n\nconst busyRaw = $input.all().map(i => i.json).filter(Boolean);\nconst busy = busyRaw\n  .map(b => ({\n    start: DateTime.fromISO(b.start || b.startTime || b.timeMin, { zone: tz }),\n    end:   DateTime.fromISO(b.end   || b.endTime   || b.timeMax, { zone: tz })\n  }))\n  .filter(b => b.start.isValid && b.end.isValid)\n  .sort((a, b) => a.start - b.start);\n\nconst overlapsBusy = (slotStart, slotEnd) =>\n  busy.some(b => slotStart < b.end && slotEnd > b.start);\n\nconst SLOT_MIN = 30;\nconst slots = [];\nlet day = DateTime.now().setZone(tz).plus({ days: 1 }).startOf('day');\nlet daysChecked = 0;\nwhile (slots.length < 3 && daysChecked < 7) {\n  const weekday = day.weekday;\n  if (weekday >= 1 && weekday <= 5) {\n    for (let h = 9; h < 18 && slots.length < 3; h++) {\n      for (const m of [0, 30]) {\n        const slotStart = day.set({ hour: h, minute: m });\n        const slotEnd = slotStart.plus({ minutes: SLOT_MIN });\n        if (slotStart < DateTime.now().setZone(tz).plus({ hours: 2 })) continue;\n        if (overlapsBusy(slotStart, slotEnd)) continue;\n        slots.push({\n          startISO: slotStart.toISO(),\n          endISO:   slotEnd.toISO(),\n          readable: slotStart.toFormat(\"cccc, LLL d 'at' h:mm a\") + ' ' + slotStart.toFormat('ZZZZ')\n        });\n        if (slots.length >= 3) break;\n      }\n    }\n  }\n  day = day.plus({ days: 1 });\n  daysChecked++;\n}\n\nreturn [{ json: { ...email, slots, slotsText: slots.map((s, i) => `${i + 1}. ${s.readable}`).join('\\n') } }];"
      },
