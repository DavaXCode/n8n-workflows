      "parameters": {
        "jsCode": "const body = $input.first().json.body ?? $input.first().json;\nconst payload = body.payload ?? body;\n\nconst bookingId = payload.uid ?? payload.bookingId ?? 'unknown';\nconst attendees = payload.attendees ?? [];\nconst guestName = attendees[0]?.name ?? payload.responses?.name?.value ?? 'Unknown';\nconst guestEmail = attendees[0]?.email ?? payload.responses?.email?.value ?? '';\nconst startTime = payload.startTime ?? payload.startTimestamp ?? '';\nconst meetLink = payload.videoCallUrl ?? payload.metadata?.videoCallUrl ?? '';\n\nconst months = ['January','February','March','April','May','June','July','August','September','October','November','December'];\nlet readableTime = 'Time not available';\nlet calendarUrlGoogle = '', calendarUrlOutlook = '', calendarUrlYahoo = '', calendarUrlApple = '';\n\nif (startTime) {\n  const dt = new Date(startTime);\n  if (!isNaN(dt)) {\n    const month = months[dt.getUTCMonth()];\n    const day = dt.getUTCDate();\n    let hours = dt.getUTCHours();\n    const minutes = String(dt.getUTCMinutes()).padStart(2, '0');\n    const ampm = hours >= 12 ? 'PM' : 'AM';\n    hours = hours % 12 || 12;\n    readableTime = `${month} ${day} at ${hours}:${minutes} ${ampm} UTC`;\n\n    const end = new Date(dt.getTime() + 30 * 60 * 1000);\n    const fmt = (d) => d.toISOString().replace(/[-:.]/g,'').slice(0,15) + 'Z';\n\n    const title = encodeURIComponent('30-min call with Andrei');\n    const desc  = encodeURIComponent('Join via Google Meet: ' + meetLink);\n    const loc   = encodeURIComponent(meetLink || 'Online');\n\n    calendarUrlGoogle  = `https://calendar.google.com/calendar/render?action=TEMPLATE&text=${title}&dates=${fmt(dt)}/${fmt(end)}&details=${desc}&location=${loc}`;\n    calendarUrlOutlook = `https://outlook.live.com/calendar/0/deeplink/compose?subject=${title}&startdt=${encodeURIComponent(dt.toISOString())}&enddt=${encodeURIComponent(end.toISOString())}&body=${desc}&location=${loc}`;\n    const yFmt = (d) => d.toISOString().replace(/[-:]/g,'').replace(/\\.\\d{3}Z/,'Z');\n    calendarUrlYahoo   = `https://calendar.yahoo.com/?v=60&title=${title}&st=${yFmt(dt)}&et=${yFmt(end)}&desc=${desc}&in_loc=${loc}`;\n    const ics = `BEGIN:VCALENDAR\\r\\nVERSION:2.0\\r\\nBEGIN:VEVENT\\r\\nDTSTART:${fmt(dt)}\\r\\nDTEND:${fmt(end)}\\r\\nSUMMARY:30-min call with Andrei\\r\\nDESCRIPTION:Join via Google Meet: ${meetLink}\\r\\nLOCATION:${meetLink || 'Online'}\\r\\nEND:VEVENT\\r\\nEND:VCALENDAR`;\n    calendarUrlApple   = 'data:text/calendar;charset=utf-8,' + encodeURIComponent(ics);\n  }\n}\n\nreturn [{ json: { bookingId, guestName, guestEmail, startTime, meetLink, readableTime, calendarUrlGoogle, calendarUrlOutlook, calendarUrlYahoo, calendarUrlApple } }];"
      },
