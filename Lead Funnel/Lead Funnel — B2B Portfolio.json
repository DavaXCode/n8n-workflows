    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body ?? $input.first().json;\nconst { name, email, message, company = '', role = '', inquiry = '', budget_range = '' } = body;\n\nif (!name || !email) {\n  throw new Error('Missing required fields: name, email');\n}\n\nreturn [{\n  json: {\n    name: String(name).trim(),\n    email: String(email).toLowerCase().trim(),\n    company: String(company).trim(),\n    role: String(role).trim(),\n    inquiry: String(inquiry).trim(),\n    message: String(message || '').trim(),\n    budget_range: String(budget_range).trim(),\n    timestamp: new Date().toISOString()\n  }\n}];"
      },
      "id": "14fe539b-6c71-4dba-992d-d1fad95c67df",
      "name": "Validate & Normalize",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -1120,
        192
      ]
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "=Qualify this B2B lead and generate a 3-4 step n8n automation plan:\nName: {{ $json.name }}\nCompany: {{ $json.company }}\nRole: {{ $json.role }}\nMessage: {{ $json.message }}\n\nScoring: 8-10=decision maker with urgent need and budget, 5-7=interested prospect, 1-4=low intent.\n\nFor solution_steps: 3-4 specific n8n workflow steps that directly solve their stated problem. Each step max 90 chars, starts with action verb, references real tools (Gmail, Slack, Sheets, webhook, CRM) where relevant.",
        "hasOutputParser": true,
        "messages": {
          "messageValues": [
            {
              "message": "You are a B2B lead qualification expert specializing in n8n automation. Analyze the lead and qualify it. Return a score 1-10, a <=100-char summary, an intent (one of demo_request, pricing_inquiry, general_question, partnership), a one-sentence problem statement, and 3-4 solution_steps."
            }
          ]
        },
        "batching": {}
      },
      "id": "114e40b3-056b-48f8-82fc-5b578cfe19f9",
      "name": "Groq AI Enrichment",
      "type": "@n8n/n8n-nodes-langchain.chainLlm",
      "typeVersion": 1.9,
      "position": [
        -896,
        192
