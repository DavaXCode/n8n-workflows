    {
      "parameters": {
        "jsCode": "const lead = $('Validate & Normalize').first().json;\nconst out = $input.first().json.output ?? {};\n\nlet aiData = {\n  score: 5,\n  summary: 'Could not analyse lead',\n  intent: 'general_question',\n  problem: 'Needs an automation solution',\n  solution_steps: [\n    'Connect contact form to n8n via webhook trigger',\n    'Process and route data based on business rules',\n    'Send automated responses via email and Slack',\n    'Log all activity to Google Sheets for visibility'\n  ]\n};\nif (out && typeof out === 'object') aiData = { ...aiData, ...out };\n\nconst pricingInquiries = ['ai-automation', 'complex-automation', 'web-dev'];\nconst minScore = pricingInquiries.includes(lead.inquiry) ? 8 : 1;\n\nconst score = Math.min(10, Math.max(minScore, parseInt(aiData.score) || 5));\nlet tier, tier_index;\nif (score >= 8)      { tier = 'hot';  tier_index = 0; }\nelse if (score >= 5) { tier = 'warm'; tier_index = 1; }\nelse                 { tier = 'cold'; tier_index = 2; }\n\nconst solution_steps = Array.isArray(aiData.solution_steps)\n  ? aiData.solution_steps.slice(0, 4)\n  : [];\n\nreturn [{ json: {\n  ...lead,\n  score,\n  tier,\n  tier_index,\n  ai_summary: String(aiData.summary || '').slice(0, 100),\n  problem: String(aiData.problem || '').slice(0, 200),\n  solution_steps,\n  intent: aiData.intent || 'general_question',\n  status: 'New'\n}}];"
      },
