    {
      "parameters": {
        "jsCode": "const items = $input.all();\n  if (items.length === 0) return [];\n\n  const now = new Date();\n  const months =\n  ['January','February','March','April','May','June','July','August','September','October','November','December'];\n\n  const upcoming = [];\n  items.forEach((item, i) => {\n    const obj = item.json || {};\n    const reminded = String(obj['Reminded'] || '').trim().toUpperCase();\n    if (reminded === 'TRUE') return;\n\n    const startTime = obj['Start Time'];\n    if (!startTime) return;\n\n    const dt = new Date(startTime);\n    if (isNaN(dt)) return;\n\n    const diffMin = (dt - now) / (1000 * 60);\n    if (diffMin >= 50 && diffMin <= 70) {\n      const month = months[dt.getUTCMonth()];\n      const day = dt.getUTCDate();\n      let hours = dt.getUTCHours();\n      const minutes = String(dt.getUTCMinutes()).padStart(2, '0');\n      const ampm = hours >= 12 ? 'PM' : 'AM';\n      hours = hours % 12 || 12;\n      const readableTime = `${month} ${day} at ${hours}:${minutes} ${ampm} UTC`;\n      upcoming.push({ json: { ...obj, readableTime, _rowIndex: i + 2 } });\n    }\n  });\n\n  return upcoming;"
      },
