    {
      "parameters": {
        "jsonSchemaExample": "{ \"score\": 8, \"summary\": \"Short summary\", \"intent\": \"demo_request\", \"problem\": \"One-sentence problem\", \"solution_steps\": [\"Step 1\", \"Step 2\", \"Step 3\"] }"
      },
      "id": "87b749f8-e6b5-4b8e-bdc8-a46c7cce2713",
      "name": "Lead JSON Parser",
      "type": "@n8n/n8n-nodes-langchain.outputParserStructured",
